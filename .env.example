# Copy this file to .env and fill in real values before deploying.

# Long random string — used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_dev_only_secret

# Port the server listens on (most hosts like Railway/Render set this for you automatically)
PORT=4000

# Comma-free single origin of your deployed frontend, e.g. https://ledger.yourcompany.com
# Use * only for local development/testing, never in production.
CORS_ORIGIN=*
